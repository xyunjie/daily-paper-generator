{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "usersacceptedpublicgithubdaily-paper-generator",
  "version": "0.1.0",
  "identifier": "com.dailypaper.generator",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "usersacceptedpublicgithubdaily-paper-generator",
        "width": 1400,
        "height": 800,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:daily.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
