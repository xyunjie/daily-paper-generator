{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "日报工具",
  "mainBinaryName": "DailyPaperTool",
  "version": "1.0.0",
  "identifier": "com.dailypaper.tool",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "日报工具",
        "width": 1400,
        "height": 800,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:daily.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "app", "appimage", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
